---
import '../styles/global.css';
import ThemeSelector from '@/components/ThemeSelector.astro';
import ThemeScript from '@/components/ThemeScript.astro';
import { RefreshCw, Mail } from '@lucide/astro';
import SpotifyIcon from '../assets/spotify-icon.svg';
import GoogleIcon from '../assets/google-icon.svg';
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Now Playing | kazui.dev</title>
    <meta name="description" content="今聴いてる曲です。" />  
    <meta property="og:url" content="https://now-playing.kazui.dev" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Now Playing | kazui.dev" />
    <meta property="og:description" content="今聴いてる曲です。" />
    <meta property="og:site_name" content="kazui.dev" />
    <meta id="themeColorMeta" name="theme-color" content="#ffffff" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <ThemeScript />
    
    <style>
      html {
        scrollbar-gutter: stable;
      }
      
      body {
        font-family: 'Inter', 'Noto Sans JP', sans-serif;
      }
      
      .theme-transitioning,
      .theme-transitioning *,
      .theme-transitioning *::before,
      .theme-transitioning *::after {
        transition: none !important;
        animation: none !important;
      }
    </style>
  </head>
  <body class="bg-white dark:bg-slate-900 min-h-screen flex flex-col">
    <header class="pt-2 px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <div class="flex-1"></div>
        <h1 class="text-xl font-medium text-gray-900 dark:text-slate-100">
          kazui.dev
        </h1>
        <div class="flex-1 flex justify-end">
          <ThemeSelector />
        </div>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 flex-1 w-full">
      <section class="border border-gray-200 dark:border-slate-700 rounded-2xl bg-white dark:bg-slate-800 p-6 sm:p-8 shadow-sm">
        <div class="flex flex-col sm:flex-row gap-6">
          <div class="relative mx-auto sm:mx-0 h-36 w-36 sm:h-42 sm:w-42 rounded-xl overflow-hidden bg-slate-100 dark:bg-slate-700 flex items-center justify-center">
            <img
              id="trackImage"
              alt="Album artwork"
              class="absolute inset-0 z-10 h-full w-full object-cover opacity-0 transition-opacity duration-700 ease-out"
            />
            <span id="imagePlaceholder" class="text-xs text-slate-500 dark:text-slate-300">
              No Artwork
            </span>
          </div>

          <div class="flex-1 min-w-0">
            <p id="statusLabel" class="text-xs font-semibold tracking-widest text-slate-500 dark:text-slate-400 transition-opacity duration-150 ease-in-out opacity-100">
              LOADING
            </p>
            <h2 id="trackTitle" class="mt-2 min-h-8 text-2xl font-semibold text-slate-900 dark:text-slate-100 transition-opacity duration-150 ease-in-out opacity-0 pointer-events-none">
            </h2>
            <div class="mt-2 min-h-11 relative">
              <p id="trackArtists" class="text-sm text-slate-600 dark:text-slate-300 transition-opacity duration-150 ease-in-out opacity-0 pointer-events-none">
              </p>
              
              <div class="relative w-full">
                <button
                  id="reloadAction"
                  type="button"
                  class="absolute left-0 top-0 mt-1 inline-flex items-center gap-2 text-sm text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-slate-100 transition-opacity duration-150 ease-in-out opacity-0 pointer-events-none"
                >
                  <RefreshCw size={16} class="text-slate-500 dark:text-slate-300" />
                  再読み込み
                </button>
                
                <p id="trackAlbum" class="mt-1 text-sm text-slate-500 dark:text-slate-400 transition-opacity duration-150 ease-in-out opacity-0 pointer-events-none"></p>
              </div>
            </div>

            <div class="mt-6">
              <div class="flex items-center justify-between text-xs text-slate-500 dark:text-slate-400">
                <span id="elapsedTime">0:00</span>
                <span id="durationTime">0:00</span>
              </div>
              <div class="mt-2 h-1.5 w-full rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden">
                <div id="progressBar" class="h-full w-0 bg-slate-900 dark:bg-slate-100"></div>
              </div>
            </div>
            <div class="w-full flex justify-center sm:justify-start">
              <a
                id="spotifyLink"
                class="mt-6 inline-flex items-center justify-center rounded-md border border-slate-300 dark:border-slate-600 px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-200 hover:border-slate-500 dark:hover:border-slate-400 transition-opacity duration-150 ease-in-out opacity-0 pointer-events-none"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
              >
                <SpotifyIcon class="size-5 mr-2" />
                Spotifyで開く
              </a>
              <a
                id="googleSearchLink"
                class="mt-6 ml-3 inline-flex items-center justify-center rounded-md border border-slate-300 dark:border-slate-600 px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-200 hover:border-slate-500 dark:hover:border-slate-400 transition-opacity duration-150 ease-in-out opacity-0 pointer-events-none"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
              >
                <GoogleIcon class="size-4 mr-2" />
                検索
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="w-full bg-white dark:bg-slate-900 mt-auto">
      <div class="mx-auto w-full px-4 sm:px-6 py-4 flex flex-row items-center justify-center gap-5">
        <div class="flex items-center gap-3 text-slate-400">
          <a href="https://github.com/kazui-dev" target="_blank" rel="noopener noreferrer" class="hover:text-slate-600 dark:hover:text-slate-300 transition-colors" aria-label="GitHub">
            <svg role="img" viewBox="0 0 24 24" fill="currentColor" class="size-5"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" /></svg>
          </a>
          <a href="https://x.com/kazui_dev" target="_blank" rel="noopener noreferrer" class="hover:text-slate-600 dark:hover:text-slate-300 transition-colors" aria-label="X (Twitter)">
            <svg role="img" viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z" /></svg>
          </a>
          <a href="mailto:contact@kazui.dev" class="hover:text-slate-600 dark:hover:text-slate-300 transition-colors" aria-label="Email">
            <Mail class="size-5" />
          </a>
        </div>
        <p class="text-sm font-medium text-slate-500 dark:text-slate-400">
          © {new Date().getFullYear()} kazui
        </p>
      </div>
    </footer>

    <script>
      import type { NowPlayingResponse } from '../types';

      const els = {
        status: document.getElementById('statusLabel') as HTMLParagraphElement,
        title: document.getElementById('trackTitle') as HTMLHeadingElement,
        artists: document.getElementById('trackArtists') as HTMLParagraphElement,
        reload: document.getElementById('reloadAction') as HTMLButtonElement,
        album: document.getElementById('trackAlbum') as HTMLParagraphElement,
        image: document.getElementById('trackImage') as HTMLImageElement,
        elapsed: document.getElementById('elapsedTime') as HTMLSpanElement,
        duration: document.getElementById('durationTime') as HTMLSpanElement,
        progress: document.getElementById('progressBar') as HTMLDivElement,
        spotify: document.getElementById('spotifyLink') as HTMLAnchorElement,
        google: document.getElementById('googleSearchLink') as HTMLAnchorElement,
      };

      const fadeDurationMs = 150;
      const POLL_INTERVAL_MS = 3000;
      let currentData: NowPlayingResponse | null = null;
      let serverTimeOffset = 0;
      let isFetching = false;
      let endRefreshRequested = false;

      const formatTime = (ms: number) => {
        const safeMs = Number.isFinite(ms) && ms > 0 ? ms : 0;
        const totalSeconds = Math.floor(safeMs / 1000);
        return `${Math.floor(totalSeconds / 60)}:${(totalSeconds % 60).toString().padStart(2, '0')}`;
      };

      const isSameTrack = (oldD: NowPlayingResponse | null, newD: NowPlayingResponse) => {
        return oldD?.track?.title === newD?.track?.title && oldD?.isPlaying === newD?.isPlaying;
      };

      const updateEl = (el: HTMLElement, text: string | null, show: boolean) => {
        const isChanged = (text !== null && el.textContent !== text) || 
                          (el.classList.contains('opacity-100') !== show);
        
        if (!isChanged) return;

        el.classList.remove('opacity-100');
        el.classList.add('opacity-0');
        if (!show) el.classList.add('pointer-events-none');

        setTimeout(() => {
          if (text !== null) el.textContent = text;
          
          if (show) {
            el.classList.remove('opacity-0', 'pointer-events-none');
            el.classList.add('opacity-100');
          }
        }, fadeDurationMs);
      };

      const applyData = (data: NowPlayingResponse | null, isError = false) => {
        if (data && currentData && isSameTrack(currentData, data)) {
          serverTimeOffset = data.serverTime - Date.now();
          currentData = data;
          return;
        }

        const t = data?.track;
        
        const statusText = isError ? 'ERROR' : (t ? (data.isPlaying ? 'NOW PLAYING' : 'PAUSED') : 'NOT PLAYING');
        const titleText = isError ? '取得に失敗しました' : (t?.title || '再生中の曲はありません');

        updateEl(els.status, statusText, true);
        updateEl(els.title, titleText, true);
        updateEl(els.artists, t?.artists?.join(' / ') || '', !!t?.artists?.length);
        updateEl(els.album, t?.album || '', !!t?.album);

        const hasTrack = !!t;
        els.spotify.href = t?.spotifyUrl || '#';
        updateEl(els.spotify, null, hasTrack);

        els.google.href = t ? `https://www.google.com/search?q=${encodeURIComponent(t.artists.join(' ') + ' ' + t.title)}` : '#';
        updateEl(els.google, null, hasTrack);

        updateEl(els.reload, null, isError);

        const imgUrl = t?.imageUrl || '';
        if (els.image.dataset.url !== imgUrl) {
          els.image.dataset.url = imgUrl;
          els.image.classList.remove('opacity-100');
          els.image.classList.add('opacity-0');
          
          setTimeout(() => {
            if (imgUrl) {
              els.image.onload = () => {
                els.image.classList.remove('opacity-0');
                els.image.classList.add('opacity-100');
              };
              els.image.src = imgUrl;
            }
          }, fadeDurationMs);
        }

        setTimeout(() => {
          currentData = data;
          serverTimeOffset = data ? data.serverTime - Date.now() : 0;
          endRefreshRequested = false;

          if (t) {
            els.duration.textContent = formatTime(t.durationMs);
          } else {
            els.elapsed.textContent = '0:00';
            els.duration.textContent = '0:00';
            els.progress.style.width = '0%';
          }
        }, fadeDurationMs);
      };

      const updateProgress = () => {
        if (!currentData?.track) {
          requestAnimationFrame(updateProgress);
          return;
        }

        const { progressMs, isPlaying, startAt, endAt } = currentData;
        const durationMs = currentData.track.durationMs || 0; // ← 修正: trackの中から取得
        const now = Date.now() + serverTimeOffset;
        const start = startAt ?? now - (progressMs || 0);
        const end = endAt ?? start + durationMs;
        
        const currentMs = isPlaying
            ? Math.min(Math.max(now - start, 0), durationMs)
            : Math.min(progressMs || 0, durationMs);

        els.progress.style.width = `${durationMs > 0 ? (currentMs / durationMs) * 100 : 0}%`;
        els.elapsed.textContent = formatTime(currentMs);

        if (isPlaying && !endRefreshRequested && now >= end) {
          endRefreshRequested = true;
          fetchNowPlaying();
        }

        requestAnimationFrame(updateProgress);
      };

      const fetchNowPlaying = async () => {
        if (isFetching) return;
        isFetching = true;
        try {
          const res = await fetch('/api/now-playing', { cache: 'no-store' });
          if (!res.ok) throw new Error();
          applyData(await res.json());
        } catch {
          applyData(null, true);
        } finally {
          isFetching = false;
        }
      };

      els.reload.addEventListener('click', fetchNowPlaying);
      fetchNowPlaying();
      setInterval(fetchNowPlaying, POLL_INTERVAL_MS);
      requestAnimationFrame(updateProgress);
    </script>
  </body>
</html>
